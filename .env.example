# Copy this file to .env and fill in your values

# Supabase — get from https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Brevo (Sendinblue) — get from https://app.brevo.com → SMTP & API → API Keys
VITE_BREVO_API_KEY=your_brevo_api_key_here
# Must be a verified sender email in your Brevo account
VITE_BREVO_SENDER_EMAIL=your_verified_sender@yourdomain.com
